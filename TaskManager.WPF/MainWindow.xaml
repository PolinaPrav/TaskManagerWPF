<Window x:Class="TaskManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер задач" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📋 Менеджер задач" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="🔍 Поиск "/>
            <TextBox x:Name="SearchTextBox" Width="200" Margin="5,0,10,5"
                     ToolTip="Поиск по названию или описанию"
                     TextChanged="SearchTextBox_TextChanged"/>

            <ComboBox x:Name="SortComboBox" Width="150" Margin="10,0,10,0"
                      SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По приоритету"/>
                <ComboBoxItem Content="По сроку"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <TextBlock Text="Фильтр:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="FilterComboBox" Width="120"
                          SelectionChanged="FilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Новая"/>
                    <ComboBoxItem Content="ВПроцессе"/>
                    <ComboBoxItem Content="Завершена"/>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <ListBox x:Name="TasksListBox" Grid.Row="2" 
                 SelectionMode="Single"
                 Margin="0,0,0,10"
                 MouseDoubleClick="TasksListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="1" 
                            CornerRadius="5" Padding="10" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding ImportantMark}" 
                                       FontSize="20" Margin="0,0,10,0"/>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Foreground="Gray"/>
                                <WrapPanel>
                                    <TextBlock Text="Приоритет: " FontWeight="Semibold"/>
                                    <TextBlock Text="{Binding Priority}"/>
                                    <TextBlock Text=" | " />
                                    <TextBlock Text="Срок: " FontWeight="Semibold"/>
                                    <TextBlock Text="{Binding DueDate, StringFormat=dd.MM.yyyy}"/>
                                    <TextBlock Text=" | " />
                                    <TextBlock Text="Статус: " FontWeight="Semibold"/>
                                    <TextBlock Text="{Binding Status}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <WrapPanel Grid.Row="3" HorizontalAlignment="Center">
            <Button Content="➕ Добавить" Style="{StaticResource ActionButton}"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                    Click="AddButton_Click"/>
            <Button Content="✏️ Редактировать" Style="{StaticResource ActionButton}"
                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="EditButton_Click"/>
            <Button Content="🗑️ Удалить" Style="{StaticResource ActionButton}"
                    Background="#F44336" Foreground="White" FontWeight="Bold"
                    Click="DeleteButton_Click"/>
            <Button Content="📊 Статистика" Style="{StaticResource ActionButton}"
                    Background="#FF9800" Foreground="White" FontWeight="Bold"
                    Click="StatisticsButton_Click"/>
            <Button Content="💾 Сохранить" Style="{StaticResource ActionButton}"
                    Background="#9C27B0" Foreground="White" FontWeight="Bold"
                    Click="SaveButton_Click"/>
            <Button Content="📂 Загрузить из файла" Style="{StaticResource ActionButton}"
                    Background="#607D8B" Foreground="White" FontWeight="Bold"
                    Click="LoadButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>