<Window x:Class="TaskManager.WPF.Windows.EditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✏️ Редактирование задачи" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Редактирование задачи" Grid.Row="0" Grid.ColumnSpan="2" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:" FontWeight="Bold" VerticalAlignment="Top" Margin="0,5"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="2" Grid.Column="1" Margin="0,5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Приоритет:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="PriorityComboBox" Grid.Row="3" Grid.Column="1" Margin="0,5" Height="30">
            <ComboBoxItem Content="Низкий"/>
            <ComboBoxItem Content="Средний"/>
            <ComboBoxItem Content="Высокий"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Срок:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="DueDatePicker" Grid.Row="4" Grid.Column="1" Margin="0,5" Height="30"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="5" Grid.Column="1" Margin="0,5" Height="30">
            <ComboBoxItem Content="Новая"/>
            <ComboBoxItem Content="ВПроцессе"/>
            <ComboBoxItem Content="Завершена"/>
        </ComboBox>

        <CheckBox x:Name="ImportantCheckBox" Grid.Row="6" Grid.ColumnSpan="2" 
                  Content="⭐ Пометить как важную" FontWeight="Bold"
                  Margin="0,10" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="💾 Сохранить" Width="120" Height="40" 
                    Margin="0,0,10,0" Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="❌ Отмена" Width="120" Height="40"
                    Background="#F44336" Foreground="White" FontWeight="Bold"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>